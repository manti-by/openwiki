{
  "name": "@manti-by/openwiki",
  "version": "0.3.0-b",
  "description": "OpenCode plugin that maintains a local, per-project session wiki: a Wiki Agent summarizes noteworthy sessions into wiki/, and a Consistency Agent keeps the index and pages honest over time.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "commands"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "wiki",
    "knowledge-base"
  ],
  "license": "AGPL-3.0",
  "author": "OpenWiki contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manti-by/openwiki.git"
  },
  "homepage": "https://github.com/manti-by/openwiki#readme",
  "bugs": {
    "url": "https://github.com/manti-by/openwiki/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --external @opencode-ai/plugin",
    "build:types": "tsc --declaration --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "bun test",
    "check": "npm run lint && npm run typecheck && npm run test",
    "prepublishOnly": "npm run build && npm run build:types",
    "prepack": "npm run build && npm run build:types"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@opencode-ai/plugin": "^1.17.20",
    "@types/node": "^22.0.0",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "@types/bun": "latest"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.17.20"
  }
}
